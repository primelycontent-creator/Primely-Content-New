generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BRAND
  CREATOR
  STAFF
}

enum LicenseTerm {
  M1
  M3
  M6
  M12
  UNLIMITED
}

enum DeliverableStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
}

enum BrandReviewStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
}

enum BriefStatus {
  DRAFT
  SUBMITTED
  REVIEW
  IN_PROGRESS
  DONE
  DECLINED
}

enum CreatorWorkMode {
  FULL_TIME
  PART_TIME
}

enum CreatorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_BRIEF
  CREATOR_UPLOAD
  STAFF_CHANGES_REQUESTED
  BRAND_CHANGES_REQUESTED
  BRAND_APPROVED
  DELIVERABLE_REPLACED
  DELIVERABLE_LOCKED
  PROFILE_REMINDER
  SUPPORT_NEW_TICKET
  SUPPORT_NEW_MESSAGE
  LEGAL_UPDATE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum LegalDocumentType {
  BRAND_TERMS
  CREATOR_TERMS
  AGENCY_TERMS
  PRIVACY_POLICY
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  agbAcceptedAt     DateTime?

  termsVersion   String?
  privacyVersion String?
  agbVersion     String?

  emailNotificationsEnabled Boolean @default(true)
  inAppNotificationsEnabled Boolean @default(true)

  emailConfirmedAt DateTime?

  settings UserSettings?

  notifications Notification[]

  brandProfile   BrandProfile?
  creatorProfile CreatorProfile?

  briefs         Brief[] @relation("BriefsByBrand")
  assignedBriefs Brief[] @relation("BriefAssignedCreator")

  assets       Asset[]
  deliverables Deliverable[] @relation("DeliverablesByCreator")

  supportTickets  SupportTicket[]  @relation("SupportTicketsByUser")
  supportMessages SupportMessage[] @relation("SupportMessagesBySender")

  legalAcceptances        LegalAcceptance[] @relation("AcceptedByUser")
  creatorApprovedProfiles CreatorProfile[]  @relation("CreatorApprovedByUser")
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique

  inAppNotifications Boolean @default(true)
  emailNotifications Boolean @default(true)

  notifyNewBrief      Boolean @default(true)
  notifyCreatorUpload Boolean @default(true)
  notifyStaffChanges  Boolean @default(true)
  notifyBrandChanges  Boolean @default(true)
  notifyApprovals     Boolean @default(true)
  notifySupport       Boolean @default(true)
  notifyLegalUpdates  Boolean @default(true)

  deleteRequestedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deleteRequestedAt])
}

model BrandProfile {
  id     String @id @default(cuid())
  userId String @unique

  companyName  String?
  contactName  String?
  contactEmail String?
  contactPhone String?

  websiteUrl   String?
  billingEmail String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  postalCode   String?
  country      String?

  logoAssetId String? @unique
  logoAsset   Asset?  @relation("BrandLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)

  isOnboarded Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([logoAssetId])
}

model CreatorProfile {
  id     String @id @default(cuid())
  userId String @unique

  fullName String?
  phone    String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  postalCode   String?
  country      String?

  workMode     CreatorWorkMode?
  nicheGroup   String?
  niches       String[] @default([])
  portfolioUrl String?
  bio          String?

  instagram String?
  tiktok    String?

  equipment     String[] @default([])
  price30sCents Int?

  profileImageAssetId String? @unique
  profileImageAsset   Asset?  @relation("CreatorProfileImage", fields: [profileImageAssetId], references: [id], onDelete: SetNull)

  introVideoAssetId String? @unique
  introVideoAsset   Asset?  @relation("CreatorIntroVideo", fields: [introVideoAssetId], references: [id], onDelete: SetNull)

  isOnboarded Boolean @default(false)

  approvalStatus   CreatorApprovalStatus @default(PENDING)
  approvedAt       DateTime?
  approvedByUserId String?
  approvedByUser   User? @relation("CreatorApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectionReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([introVideoAssetId])
  @@index([profileImageAssetId])
  @@index([approvalStatus])
  @@index([approvedByUserId])
}

model Brief {
  id      String @id @default(cuid())
  brandId String

  title       String
  description String?

  companyName  String?
  contactName  String?
  contactEmail String?
  contactPhone String?

  deadline    DateTime?
  licenseTerm LicenseTerm?

  nicheGroup String?
  niches     String[] @default([])

  status BriefStatus @default(DRAFT)

  deliverableCount Int @default(1)

  assignedCreatorId String?
  assignedCreator   User? @relation("BriefAssignedCreator", fields: [assignedCreatorId], references: [id], onDelete: SetNull)

  consultationRequired      Boolean  @default(true)
  consultationBooked        Boolean  @default(false)
  consultationBookedAt      DateTime?
  consultationEventType     String?
  consultationBookingUid    String?  @unique
  consultationBookingUrl    String?
  consultationAttendeeName  String?
  consultationAttendeeEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand User @relation("BriefsByBrand", fields: [brandId], references: [id], onDelete: Cascade)

  deliverables   Deliverable[]
  assets         BriefAsset[]
  supportTickets SupportTicket[]

  @@index([brandId])
  @@index([assignedCreatorId])
  @@index([status])
  @@index([consultationBooked])
  @@index([consultationBookingUid])
}

model Deliverable {
  id        String @id @default(cuid())
  briefId   String
  creatorId String

  slotIndex Int @default(1)

  revision Int     @default(1)
  isLatest Boolean @default(true)

  status DeliverableStatus @default(PENDING)

  staffFeedback   String?
  staffReviewedAt DateTime?

  brandStatus     BrandReviewStatus @default(PENDING)
  brandFeedback   String?
  brandReviewedAt DateTime?

  isLocked Boolean @default(false)
  lockedAt DateTime?

  replacesDeliverableId String?
  replacesDeliverable   Deliverable?  @relation("DeliverableReplacementChain", fields: [replacesDeliverableId], references: [id], onDelete: SetNull)
  replacedBy            Deliverable[] @relation("DeliverableReplacementChain")

  bucket    String
  path      String
  fileName  String?
  mimeType  String?
  sizeBytes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brief   Brief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  creator User  @relation("DeliverablesByCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([briefId, creatorId, slotIndex, revision])
  @@index([briefId])
  @@index([creatorId])
  @@index([slotIndex])
  @@index([briefId, slotIndex])
  @@index([briefId, creatorId, slotIndex, isLatest])
  @@index([replacesDeliverableId])
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  bucket    String
  path      String
  mimeType  String?
  fileName  String?
  sizeBytes Int?
  status    String   @default("UPLOADED")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  creatorIntroVideo   CreatorProfile? @relation("CreatorIntroVideo")
  creatorProfileImage CreatorProfile? @relation("CreatorProfileImage")
  brandLogo           BrandProfile?   @relation("BrandLogo")
  briefAssets         BriefAsset[]

  @@unique([bucket, path])
  @@index([userId])
}

model BriefAsset {
  briefId String
  assetId String

  brief Brief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([briefId, assetId])
  @@index([assetId])
}

model SupportTicket {
  id        String              @id @default(cuid())
  userId    String
  briefId   String?
  subject   String
  status    SupportTicketStatus @default(OPEN)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user     User             @relation("SupportTicketsByUser", fields: [userId], references: [id], onDelete: Cascade)
  brief    Brief?           @relation(fields: [briefId], references: [id], onDelete: SetNull)
  messages SupportMessage[]

  @@index([userId])
  @@index([briefId])
  @@index([status])
  @@index([updatedAt])
}

model SupportMessage {
  id           String   @id @default(cuid())
  ticketId     String
  senderUserId String?
  senderRole   UserRole
  message      String
  createdAt    DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User?         @relation("SupportMessagesBySender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([senderUserId])
  @@index([createdAt])
}

model LegalDocument {
  id        String            @id @default(cuid())
  type      LegalDocumentType
  version   String
  title     String
  slug      String            @unique
  content   String
  isActive  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  acceptances LegalAcceptance[]

  @@unique([type, version])
  @@index([type, isActive])
}

model LegalAcceptance {
  id         String   @id @default(cuid())
  userId     String
  documentId String
  acceptedAt DateTime @default(now())

  user     User          @relation("AcceptedByUser", fields: [userId], references: [id], onDelete: Cascade)
  document LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId])
  @@index([documentId])
}
model CalendarBooking {
  id              String   @id @default(cuid())
  calBookingId    String?  @unique
  calUid          String?  @unique
  triggerEvent    String
  eventTypeId     Int?
  eventTitle      String?
  bookingType     String?
  briefId         String?
  attendeeName    String?
  attendeeEmail   String?
  attendeePhone   String?
  startTime       DateTime?
  endTime         DateTime?
  videoCallUrl    String?
  status          String?
  rawPayload      Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}